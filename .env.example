# =============================================================================
# Trading Copilot — example environment variables
# Copy this file to .env and fill in actual values. NEVER commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend (apps/api)
# -----------------------------------------------------------------------------

# Postgres + TimescaleDB (docker-compose default)
DATABASE_URL=postgresql+asyncpg://trading:trading@localhost:5432/trading

# Valkey (docker-compose default)
VALKEY_URL=redis://localhost:6379/0

# FastAPI app
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO

# CORS — allow Next.js dev server (3000 is default, 3001 is fallback when something
# else is on 3000). Comma-separated list.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Binance — F0 only uses MAINNET_RO (public data, no key needed).
# These slots are placeholders for F4+ when we add testnet execution.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_MAINNET_API_KEY=
BINANCE_MAINNET_API_SECRET=

# Símbolos USDT-M de Binance que la ingesta live mantiene en stream + DB.
# CSV. Cada uno corre los 5 timeframes estándar (1m/15m/1h/4h/1d). La sidebar
# del frontend los muestra en este orden. Cambiar requiere reiniciar la API.
WATCH_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT

# -----------------------------------------------------------------------------
# Frontend (apps/web)
# -----------------------------------------------------------------------------

# Public URL of the FastAPI backend (used by the browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
